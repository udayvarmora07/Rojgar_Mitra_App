# Supabase Configuration
# Get these values from your Supabase project dashboard -> Settings -> API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# MiniMax API Configuration (for AI practice tests)
# Get this from MiniMax platform
MINIMAX_API_KEY=your-minimax-api-key

# Note: EXPO_PUBLIC_ prefix is required for Expo to include env vars in the native bundle
# Never expose Service Role Key in frontend code - use only in Supabase Edge Functions